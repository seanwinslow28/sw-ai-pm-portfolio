---
/**
 * <DeepDiveTitleBlock /> — dateline + surface/status pills + h1.
 *
 * Top-of-page block on /transactions/<slug>/. Pairs with
 * <ValuePropPullQuote /> below (separate component since the
 * pullquote has its own typographic register).
 *
 * View Transition: the h1 carries `view-transition-name: ledger-title-<slug>`
 * — the morph target from the index ledger row (Task 4.3).
 *
 * Per transactions-spec §2.2 + §5 + §9.1 steps 1-3 + §15.
 */
interface Props {
  slug: string;
  dateline: string;          // "BOSTON, MAY 13, 2026 — phase d typed reasoning edges, shipped."
  surface: string;
  status: string;
  title: string;
}
const { slug, dateline, surface, status, title } = Astro.props;
const statusClass = `status-pill status-${status.toLowerCase()}`;
---

<header class="title-block">
  <p class="dateline">{dateline}</p>
  <hr class="dateline-rule" />

  <p class="pills">
    <span class="surface-pill">{surface.toUpperCase()}</span>
    <span class="pills-sep" aria-hidden="true">·</span>
    <span class={statusClass}>{status}</span>
  </p>

  <h1 class="page-title" style={`view-transition-name: ledger-title-${slug}`}>
    {title}
  </h1>
</header>

<style>
  .title-block {
    max-width: 1120px;
    margin: 60px auto 0;
    padding: 0 24px;
  }
  .dateline {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    color: var(--ink-secondary);
    margin: 0;
  }
  .dateline-rule {
    border: none;
    border-bottom: 0.5px solid var(--border-paper);
    margin: 16px 0 24px;
  }

  .pills {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    margin: 0 0 12px;
    display: flex;
    gap: 12px;
    align-items: baseline;
  }
  .surface-pill {
    color: var(--ink);
    border: 1px solid var(--ink);
    padding: 3px 8px;
  }
  .pills-sep { color: var(--border-paper); }
  .status-pill {
    padding: 3px 8px;
  }
  .status-active   { color: var(--stamp-amber);     border: 1px solid var(--stamp-amber); }
  .status-shipped  { color: var(--success-teal);    border: 1px solid var(--success-teal); }
  .status-paused   { color: var(--ink-secondary);   border: 1px solid var(--ink-secondary); }
  .status-archived { color: var(--ink-secondary);   border: 1px solid var(--ink-secondary); opacity: 0.7; }

  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(40px, 5vw, 72px);
    font-weight: 400;
    letter-spacing: -0.4px;
    color: var(--teal);
    margin: 0;
    line-height: 1.05;
    max-width: 880px;
  }

  @media (max-width: 767px) {
    .title-block { padding: 0 16px; margin-top: 40px; }
    .page-title { font-size: clamp(32px, 8vw, 48px); }
  }
</style>
