---
/**
 * <RelatedBlock /> — essays deep-dive Related block.
 *
 * Renders:
 *   - relatedLedgerRow → /transactions/<slug>/
 *   - relatedCaseStudy → /work/<slug>/
 *   - relatedArchitecture[] → architecture writeups
 *   - relatedEssays[] (forward + reverse via .crosslinks.json)
 *
 * Per essays-spec §14.
 */
interface ReverseShape { siblingEssays?: string[] }
interface Crosslinks { essays?: Record<string, ReverseShape> }

interface Props {
  slug: string;
  relatedLedgerRow?: string;
  relatedCaseStudy?: string;
  relatedArchitecture?: string[];
  relatedEssays?: string[];
  crosslinks: Crosslinks;
  titleByEssaySlug: Record<string, string>;
  titleByTxnSlug: Record<string, string>;
  titleByWorkSlug: Record<string, string>;
  titleByArchSlug: Record<string, string>;
}
const {
  slug,
  relatedLedgerRow,
  relatedCaseStudy,
  relatedArchitecture = [],
  relatedEssays = [],
  crosslinks,
  titleByEssaySlug,
  titleByTxnSlug,
  titleByWorkSlug,
  titleByArchSlug,
} = Astro.props;

const reverse = crosslinks.essays?.[slug] ?? {};
const siblingEssays = Array.from(new Set([
  ...relatedEssays,
  ...(reverse.siblingEssays ?? []),
]));
const hasAny = Boolean(relatedLedgerRow || relatedCaseStudy || relatedArchitecture.length > 0 || siblingEssays.length > 0);
---
{hasAny && (
  <section class="related-block" aria-labelledby={`related-${slug}`}>
    <h2 id={`related-${slug}`} class="section-heading">&mdash; RELATED &mdash;</h2>
    <ul class="related-list">
      {relatedLedgerRow && (
        <li><a href={`/transactions/${relatedLedgerRow}/`}>&rarr; ledger row: {titleByTxnSlug[relatedLedgerRow] ?? relatedLedgerRow}</a></li>
      )}
      {relatedCaseStudy && (
        <li><a href={`/work/${relatedCaseStudy}/`}>&rarr; companion case study: {titleByWorkSlug[relatedCaseStudy] ?? relatedCaseStudy}</a></li>
      )}
      {relatedArchitecture.map((s) => (
        <li><a href={`/architecture/${s}/`}>&rarr; companion architecture writeup: {titleByArchSlug[s] ?? s}</a></li>
      ))}
      {siblingEssays.map((s) => (
        <li><a href={`/essays/${s}/`}>&harr; sibling essay: {titleByEssaySlug[s] ?? s}</a></li>
      ))}
    </ul>
  </section>
)}
<style>
  .related-block { max-width: 1120px; margin: 64px auto 0; padding: 0 24px; }
  .section-heading {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 2.4px;
    color: var(--teal);
    opacity: 0.8;
    text-transform: uppercase;
    margin: 0 0 16px;
  }
  .related-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
  .related-list a {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.4px;
    color: var(--teal);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 160ms var(--ease-out);
  }
  .related-list a:hover, .related-list a:focus-visible { border-bottom-color: var(--teal); outline: none; }
  @media (max-width: 767px) { .related-block { padding: 0 16px; } }
</style>
