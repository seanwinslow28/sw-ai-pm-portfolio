---
/**
 * Projects-section dateline label — top-left of the splash.
 * Source: projects-spec §2.
 */
import { getCollection } from "astro:content";
import datelineData from "../../../public/api/dateline.json";

const work = await getCollection("work");
const count = work.length;
const today = datelineData.date_iso; // wired to Daily Driver's dateline.json (written 08:30 daily)
---

<div class="projects-dateline">
  <p class="label">WORK · {count} PIECES · UPDATED {today}</p>
</div>

<style>
  .projects-dateline {
    margin-bottom: 60px;
  }
  .label {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 1.6px;
    line-height: 1.4;
    color: var(--paper);
    text-transform: uppercase;
    margin: 0;
  }
  @media (max-width: 768px) {
    .label {
      font-size: 11px;
    }
  }
</style>
