---
/**
 * <IndexHeader /> — h1 + italic hook + sober subhead + metadata strip.
 *
 * Per essays-spec §2.1 + §4.1 + §5. Hook line locks to OPEN-1 default:
 * "I bet on meaning, not access." (Vault-Scorecard-style identity claim).
 */
interface Props {
  count: number;
  lastPublishedISO: string;
}
const { count, lastPublishedISO } = Astro.props;

const today = new Date();
const monthName = today.toLocaleDateString("en-US", { month: "long" }).toUpperCase();
const day = today.getDate();
const year = today.getFullYear();
const datelineBody = `${count} essay${count === 1 ? "" : "s"}.`;
---
<header class="index-header">
  <p class="dateline">
    <span class="dateline__city">BOSTON, {monthName} {day}, {year}</span>
    <span class="dateline__sep">&mdash;</span>
    <span class="dateline__body">{datelineBody}</span>
  </p>
  <hr class="dateline-rule" />
  <h1 class="page-title">Essays</h1>
  <p class="hook">I bet on meaning, not access.</p>
  <p class="subhead">Thesis-shaped writing where the artifacts back the claim.</p>
  <p class="metadata-strip">
    <span>{count} ESSAY{count === 1 ? "" : "S"}</span>
    <span aria-hidden="true">&middot;</span>
    <span>LAST PUBLISHED {lastPublishedISO}</span>
    <span aria-hidden="true">&middot;</span>
    <a href="/essays/rss.xml" class="rss-link">RSS &rarr;</a>
  </p>
</header>
<style>
  .index-header { max-width: 1120px; margin: 0 auto; padding: 60px 24px 0; }
  .dateline {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 1.6px;
    color: var(--ink-secondary);
    margin: 0 0 12px;
  }
  .dateline__city { color: var(--stamp-amber); }
  .dateline__sep { margin: 0 6px; }
  .dateline-rule { border: none; border-top: 0.5px solid rgba(10, 62, 66, 0.25); margin: 0 0 40px; }
  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(56px, 6vw, 96px);
    font-weight: 400;
    letter-spacing: -0.6px;
    line-height: 1.05;
    color: var(--teal);
    margin: 0 0 16px;
  }
  .hook {
    font-family: var(--font-serif);
    font-size: clamp(20px, 2.4vw, 32px);
    font-weight: 300;
    font-style: italic;
    letter-spacing: -0.2px;
    line-height: 1.3;
    color: var(--ink);
    margin: 0 0 16px;
    max-width: 680px;
  }
  .subhead {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 300;
    letter-spacing: -0.1px;
    line-height: 1.45;
    color: var(--ink-secondary);
    margin: 0 0 24px;
    max-width: 680px;
  }
  .metadata-strip {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 1.6px;
    color: var(--ink-secondary);
    margin: 0 0 56px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: baseline;
  }
  .metadata-strip .rss-link { color: var(--teal); text-decoration: none; border-bottom: 1px solid transparent; transition: border-color 160ms var(--ease-out); }
  .metadata-strip .rss-link:hover, .metadata-strip .rss-link:focus-visible { border-bottom-color: var(--teal); outline: none; }
  @media (max-width: 767px) { .index-header { padding: 40px 16px 0; } .metadata-strip { margin-bottom: 32px; } }
</style>
