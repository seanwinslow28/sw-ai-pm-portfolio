---
/**
 * <ThesisPullQuote /> — Newsreader-italic 1-line pullquote primitive.
 *
 * Shared by /architecture/ (architecture-spec §2.2) AND /essays/
 * (essays-spec §2.2). Same Newsreader 24px italic, 0.5px teal rules,
 * max-width 680px per BLUEPRINT §3.2. /essays/ imports from this
 * location (no fork).
 */
interface Props { text: string }
const { text } = Astro.props;
---
<blockquote class="thesis-pullquote">
  <p>{text}</p>
</blockquote>
<style>
  .thesis-pullquote {
    max-width: 680px;
    margin: 48px auto;
    padding: 32px 0;
    border-top: 0.5px solid rgba(10, 62, 66, 0.25);
    border-bottom: 0.5px solid rgba(10, 62, 66, 0.25);
  }
  .thesis-pullquote p {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(22px, 2.8vw, 32px);
    font-weight: 300;
    font-style: italic;
    letter-spacing: -0.3px;
    line-height: 1.35;
    color: var(--teal);
  }
  @media (max-width: 767px) {
    .thesis-pullquote { padding: 24px 16px; margin: 32px auto; }
  }
</style>
