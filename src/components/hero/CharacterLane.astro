---
/**
 * Hero character lane — flush-right WebM + floor shadow.
 * Source: hero-spec §7; texture-spec §5.
 *
 * 2026-05-30 (D6 / §2 AMENDMENT): the §7.5 intro icon-cycle was superseded by
 * the additive full-viewport LoadingOverlay. This lane now just mounts the WebM
 * (when motion is allowed) and fades it in. The template-based mount preserves
 * the commit `ad64ce1` reduced-motion contract — under
 * prefers-reduced-motion: reduce, NO <video> is created in the DOM at all.
 */
import { HERO_LOOP_WEBM, HERO_LOOP_POSTER } from "~/lib/site";
---

<div class="character" aria-hidden="true">
  <img
    class="hero-floor-shadow"
    src="/assets/textures/hero-floor-shadow.png"
    alt=""
    loading="eager"
    decoding="async"
  />
  <template data-hero-video-template>
    <video
      class="character-video"
      src={HERO_LOOP_WEBM}
      poster={HERO_LOOP_POSTER}
      muted
      loop
      playsinline
      preload="auto"
      data-state="pending"
    />
  </template>
</div>

<script>
  /**
   * Mount the <video> element from its <template> wrapper only when the user
   * has NOT opted into reduced-motion. Per hero-spec §7.5.5 and §12: under
   * prefers-reduced-motion: reduce, the <video> element must not appear in
   * the DOM at all (was previously rendered + CSS-hidden — a defensive measure
   * that still left a <video> in the accessibility tree). This is the
   * load-bearing commit `ad64ce1` contract.
   *
   * When motion IS allowed, the video is cloned in, played, and faded in. The
   * additive LoadingOverlay (home only, once-per-session) sits on top during
   * the first-paint cycle; the video fade-in happens behind it.
   */
  function mountVideoIfMotionAllowed() {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const existing = document.querySelector(
      ".character-video"
    ) as HTMLVideoElement | null;
    if (existing) {
      // Already mounted (re-init via pageshow / view-transition) — ensure it
      // is visible + playing.
      existing.style.opacity = "1";
      existing.play?.().catch(() => {});
      return;
    }
    const tpl = document.querySelector(
      "[data-hero-video-template]"
    ) as HTMLTemplateElement | null;
    if (!tpl || !tpl.content.firstElementChild) return;
    const video = tpl.content.firstElementChild.cloneNode(true) as HTMLVideoElement;
    tpl.parentNode?.insertBefore(video, tpl);
    // Fade in on mount.
    requestAnimationFrame(() => {
      video.style.transition = "opacity 400ms linear";
      video.style.opacity = "1";
    });
    video.play?.().catch(() => {});
  }

  // (1) Fresh page-load path
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", mountVideoIfMotionAllowed);
  } else {
    mountVideoIfMotionAllowed();
  }

  // (2) bfcache restore path — fires on back/forward navigation that
  // restored the page from the browser's back-forward cache.
  window.addEventListener("pageshow", mountVideoIfMotionAllowed);

  // (3) Astro View Transitions path — fires after each ClientRouter
  // swap. /about/ → / via the SW wordmark goes through here.
  document.addEventListener("astro:page-load", mountVideoIfMotionAllowed);
</script>

<style>
  .character {
    position: absolute;
    width: 1024px;
    height: 576px;
    right: -180px;
    bottom: 80px;
    z-index: 20;
    pointer-events: none;
  }
  .hero-floor-shadow {
    /* Calibrated 2026-05-22 (Phase 3e Bug 9) via Playwright at 3 viewport
       classes — 1920, 1440, 1024. Source PNG centroid is at 49% of its
       own width; values below align the centroid with the visual center
       of the desk legs at each viewport.

       Re-cropping the source PNG would be cleaner long-term but blocks
       on Procreate-substrate work deferred indefinitely per texture-spec.
       Per-viewport calibration remains the v1 fix. */
    position: absolute;
    width: 68%;
    height: auto;
    bottom: 7px;
    left: 26%;
    right: auto;
    object-fit: contain;
    object-position: center bottom;
    z-index: 18;
    pointer-events: none;
    opacity: 0.9;
  }
  /* Wide viewport (≥1600): the lane sits further right; nudge slightly left. */
  @media (min-width: 1600px) {
    .hero-floor-shadow {
      left: 18%;
      bottom: 4px;
    }
  }
  /* Tablet / small desktop (≤1024): lane scales down; bigger shadow + nudge. */
  @media (max-width: 1024px) {
    .hero-floor-shadow {
      width: 70%;
      left: 26%;
      bottom: -16px;
    }
  }
  .character-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: bottom right;
    z-index: 20;
    opacity: 0;
  }
  @media (max-width: 1024px) {
    .character {
      width: 420px;
      height: 240px;
      right: -24px;
      bottom: -10px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    /* Belt-and-suspenders: the JS mount step skips video creation entirely
       under reduced-motion (hero-spec §7.5.5 / §12). This CSS rule covers
       the edge case where reduced-motion flips AFTER the page has mounted
       the video (rare — most browsers don't fire matchMedia change events
       mid-session, but matchMedia listeners on the script could be added
       in v1.1 if needed). */
    .character-video {
      display: none;
    }
  }
</style>
