---
/**
 * <ScoreSymbol /> — inline SVG for ✓ / ✓✓ / ⚠ / ✗ (14×14px).
 * Palette tokens per architecture-spec §5 + §6:
 *   ✓ + ✓✓ → success teal (#0F6E56), ✓✓ is heavier stroke
 *   ⚠     → stamp amber (#7C2D12)
 *   ✗     → secondary ink (#546E71)
 *
 * Per architecture-spec §7.1 + §7.3.
 */
interface Props { symbol: "✓" | "✓✓" | "⚠" | "✗" }
const { symbol } = Astro.props;
const label =
  symbol === "✓" ? "passes" :
  symbol === "✓✓" ? "exceeds" :
  symbol === "⚠" ? "partial" :
  "fails";
---
<span class={`score-symbol score-${label}`} aria-label={label} role="img">
  {symbol === "✓" && (
    <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
      <path d="M2.5 7.5L5.5 10.5L11.5 3.5" stroke="#0F6E56" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
  )}
  {symbol === "✓✓" && (
    <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
      <path d="M1.5 7.5L4 10L8.5 4.5" stroke="#0F6E56" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      <path d="M5.5 7.5L8 10L12.5 4.5" stroke="#0F6E56" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
  )}
  {symbol === "⚠" && (
    <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
      <path d="M7 1.5L13 12H1L7 1.5Z" stroke="#7C2D12" stroke-width="1.4" stroke-linejoin="round" fill="none"/>
      <line x1="7" y1="6" x2="7" y2="9" stroke="#7C2D12" stroke-width="1.4" stroke-linecap="round"/>
      <circle cx="7" cy="10.5" r="0.7" fill="#7C2D12"/>
    </svg>
  )}
  {symbol === "✗" && (
    <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
      <line x1="3" y1="3" x2="11" y2="11" stroke="#546E71" stroke-width="1.6" stroke-linecap="round"/>
      <line x1="11" y1="3" x2="3" y2="11" stroke="#546E71" stroke-width="1.6" stroke-linecap="round"/>
    </svg>
  )}
</span>
<style>
  .score-symbol { display: inline-flex; align-items: center; justify-content: center; line-height: 0; }
</style>
