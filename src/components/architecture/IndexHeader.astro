---
/**
 * <IndexHeader /> — h1 + 1-line italic hook + sober subhead +
 *                   metadata strip for /architecture/.
 *
 * Dateline strip is build-time rendered (architecture-spec §13):
 * "BOSTON, JUNE 3, 2026 — vault scorecard shipped. 1 writeup."
 *
 * Per architecture-spec §2.1 + §4.1 + §5.
 */
interface Props {
  count: number;            // total writeups
  lastUpdatedISO: string;   // ISO YYYY-MM-DD of most recent shipped
  mostRecentTitle?: string; // for the dateline body (low-case)
}
const { count, lastUpdatedISO, mostRecentTitle } = Astro.props;

const today = new Date();
const monthName = today.toLocaleDateString("en-US", { month: "long" }).toUpperCase();
const day = today.getDate();
const year = today.getFullYear();
const datelineBody = mostRecentTitle
  ? `${mostRecentTitle.toLowerCase()} shipped. ${count} writeup${count === 1 ? "" : "s"}.`
  : `${count} writeup${count === 1 ? "" : "s"}.`;

const lastUpdatedLabel = lastUpdatedISO.replace(/-/g, "-");
---
<header class="index-header">
  <p class="dateline">
    <span class="dateline__city">BOSTON, {monthName} {day}, {year}</span>
    <span class="dateline__sep">&mdash;</span>
    <span class="dateline__body">{datelineBody}</span>
  </p>
  <hr class="dateline-rule" />
  <h1 class="page-title">Architecture</h1>
  <p class="hook">Most people see Obsidian as content. I treat my vault as agent infrastructure.</p>
  <p class="subhead">Architectural arguments where the proof is the code, linked.</p>
  <p class="metadata-strip">
    <span>{count} WRITEUP{count === 1 ? "" : "S"}</span>
    <span aria-hidden="true">&middot;</span>
    <span>UPDATED {lastUpdatedLabel}</span>
    <span aria-hidden="true">&middot;</span>
    <a href="/architecture/rss.xml" class="rss-link">RSS &rarr;</a>
  </p>
</header>
<style>
  .index-header { max-width: 1120px; margin: 0 auto; padding: 60px 24px 0; }
  .dateline {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 1.6px;
    color: var(--ink-secondary);
    margin: 0 0 12px;
  }
  .dateline__city { color: var(--stamp-amber); }
  .dateline__sep { margin: 0 6px; }
  .dateline-rule {
    border: none;
    border-top: 0.5px solid rgba(10, 62, 66, 0.25);
    margin: 0 0 40px;
  }
  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(56px, 6vw, 96px);
    font-weight: 400;
    letter-spacing: -0.6px;
    line-height: 1.05;
    color: var(--teal);
    margin: 0 0 16px;
  }
  .hook {
    font-family: var(--font-serif);
    font-size: clamp(20px, 2.4vw, 32px);
    font-weight: 300;
    font-style: italic;
    letter-spacing: -0.2px;
    line-height: 1.3;
    color: var(--ink);
    margin: 0 0 16px;
    max-width: 680px;
  }
  .subhead {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 300;
    letter-spacing: -0.1px;
    line-height: 1.45;
    color: var(--ink-secondary);
    margin: 0 0 24px;
    max-width: 680px;
  }
  .metadata-strip {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 1.6px;
    color: var(--ink-secondary);
    margin: 0 0 56px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: baseline;
  }
  .metadata-strip .rss-link {
    color: var(--teal);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 160ms var(--ease-out);
  }
  .metadata-strip .rss-link:hover,
  .metadata-strip .rss-link:focus-visible {
    border-bottom-color: var(--teal);
    outline: none;
  }
  @media (max-width: 767px) {
    .index-header { padding: 40px 16px 0; }
    .metadata-strip { margin-bottom: 32px; }
  }
</style>
