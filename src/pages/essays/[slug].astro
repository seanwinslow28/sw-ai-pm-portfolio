---
/**
 * /essays/<slug>/ — deep-dive page.
 *
 * Composes the 12-band layout per essays-spec §2.2:
 *   1. Dateline + reading-time strip
 *   2. ESSAYS + status pills row
 *   3. Title + subtitle + tags
 *   4. Published/Revised strip (conditional)
 *   5. Thesis pullquote
 *   6. Essay body (5 sections per §7 voice contract; rendered from
 *      fetched sourceUrl when present, otherwise MDX <Content />).
 *      Embedded: quadrantChart + legend + role-map table inline.
 *   7. Plotted artifacts (auto-rendered)
 *   8. 4Q block (canonical or inline-body fallback)
 *   9. Three foot-of-page links (Substack + canonical source +
 *      canonical EXPLANATION)
 *  10. Related block
 *  11. Next/Prev nav + registration mark
 *
 * Per essays-spec §2.2.
 */
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import fs from "node:fs/promises";
import path from "node:path";

import ThesisPullQuote from "~/components/architecture/ThesisPullQuote.astro";
import QuadrantChart from "~/components/essays/QuadrantChart.astro";
import QuadrantLegend from "~/components/essays/QuadrantLegend.astro";
import RoleMap from "~/components/essays/RoleMap.astro";
import PublishedRevisedStrip from "~/components/essays/PublishedRevisedStrip.astro";
import PlottedArtifacts from "~/components/essays/PlottedArtifacts.astro";
import FootLinks from "~/components/essays/FootLinks.astro";
import RelatedBlock from "~/components/essays/RelatedBlock.astro";
import FourQBlock from "~/components/case-study/FourQBlock.astro";

type Essay = CollectionEntry<"essays">;

export async function getStaticPaths() {
  const all = await getCollection("essays");
  return all.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

interface Props { entry: Essay }
const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
const slug = entry.slug;

// Adjacent essays (desc published)
const all = (await getCollection("essays")).sort((a, b) => b.data.published.localeCompare(a.data.published));
const idx = all.findIndex((t) => t.slug === entry.slug);
const next = idx >= 0 && idx + 1 < all.length ? all[idx + 1] : null;
const prev = idx > 0 ? all[idx - 1] : null;

// Cross-link graph + title lookups
const ROOT = process.cwd();
let crosslinks: any = {};
try {
  const raw = await fs.readFile(path.join(ROOT, "src/content/essays/.crosslinks.json"), "utf8");
  crosslinks = JSON.parse(raw);
} catch { /* fresh checkout */ }

const allEssays = await getCollection("essays");
const titleByEssaySlug = Object.fromEntries(allEssays.map((e) => [e.slug, e.data.title]));
const allTxn = await getCollection("transactions");
const titleByTxnSlug = Object.fromEntries(allTxn.map((t) => [t.slug, t.data.title]));
const allWork = await getCollection("work");
const titleByWorkSlug = Object.fromEntries(allWork.map((w) => [w.slug, w.data.title]));
const allArch = await getCollection("architecture");
const titleByArchSlug = Object.fromEntries(allArch.map((a) => [a.slug, a.data.title]));

const txnSlugs = new Set(allTxn.map((t) => t.slug));
const archSlugs = new Set(allArch.map((a) => a.slug));

// 4Q + body rendering
let canonicalMarkdown: string | undefined;
if (data.explanationUrl) {
  try { canonicalMarkdown = await fs.readFile(path.join(ROOT, "src/content/explanations", `${slug}.md`), "utf8"); } catch {}
}
const useFourQBlock = Boolean(canonicalMarkdown);

let essayBodyMarkdown: string | undefined;
if (data.sourceUrl) {
  try { essayBodyMarkdown = await fs.readFile(path.join(ROOT, "src/content/essays/essay-bodies", `${slug}.md`), "utf8"); } catch {}
}

const pageTitle = `${data.title} — Sean Winslow`;
const pageDescription = data.excerpt;
---
<BaseLayout title={pageTitle} description={pageDescription}>
  <article class="essay-deep-dive page-sheet">
    <header class="head-band">
      <p class="dateline">
        <span class="dateline__city">{data.dateline.split(" — ")[0] ?? data.dateline}</span>
        <span class="reading-time">{data.readingTime} MIN READ</span>
      </p>
      <hr class="dateline-rule" />
      <p class="pills-row">
        <span class="pill surface-pill">ESSAYS</span>
        <span class={`pill status-pill status-${data.status.toLowerCase()}`}>{data.status}</span>
      </p>
      <h1 class="page-title" style={`view-transition-name: essay-title-${slug}`}>{data.title}</h1>
      {data.subtitle && <p class="subtitle">{data.subtitle}</p>}
      <p class="tags">
        {data.tags.map((t, i) => (
          <>
            <span>{t}</span>{i < data.tags.length - 1 && <span class="sep" aria-hidden="true"> &middot; </span>}
          </>
        ))}
      </p>
      <PublishedRevisedStrip published={data.published} lastRevised={data.lastRevised} />
    </header>

    <ThesisPullQuote text={data.excerpt} />

    <section class="essay-body">
      {essayBodyMarkdown ? (
        <article set:html={essayBodyMarkdown} />
      ) : (
        <Content />
      )}
    </section>

    {data.mermaidSource && (
      <QuadrantChart source={data.mermaidSource} caption={data.mermaidCaption} />
    )}

    {Array.isArray(data.quadrantLegend) && data.quadrantLegend.length > 0 && (
      <QuadrantLegend entries={data.quadrantLegend} txnSlugs={txnSlugs} archSlugs={archSlugs} />
    )}

    {data.roleMap && (
      <RoleMap lastValidated={data.roleMap.lastValidated} rows={data.roleMap.rows} />
    )}

    <PlottedArtifacts
      slugs={data.plottedArtifacts ?? []}
      txnSlugs={txnSlugs}
      archSlugs={archSlugs}
      titleByTxnSlug={titleByTxnSlug}
      titleByArchSlug={titleByArchSlug}
    />

    {useFourQBlock ? (
      <FourQBlock frame="ESSAY" slug={slug} canonicalMarkdown={canonicalMarkdown} explanationUrl={data.explanationUrl ?? undefined} />
    ) : (
      <section class="inline-body-4q" aria-labelledby={`4q-${slug}`}>
        <h2 id={`4q-${slug}`} class="section-heading">&mdash; EXPLANATION &mdash;</h2>
        <div class="prose">
          {!essayBodyMarkdown && <Content />}
        </div>
      </section>
    )}

    <FootLinks
      crossPostedTo={data.crossPostedTo}
      sourceUrl={data.sourceUrl}
      explanationUrl={data.explanationUrl}
    />

    <RelatedBlock
      slug={slug}
      relatedLedgerRow={data.relatedLedgerRow ?? undefined}
      relatedCaseStudy={data.relatedCaseStudy ?? undefined}
      relatedArchitecture={data.relatedArchitecture}
      relatedEssays={data.relatedEssays}
      crosslinks={crosslinks}
      titleByEssaySlug={titleByEssaySlug}
      titleByTxnSlug={titleByTxnSlug}
      titleByWorkSlug={titleByWorkSlug}
      titleByArchSlug={titleByArchSlug}
    />

    <nav class="next-prev" aria-label="Adjacent essays">
      {next ? (
        <a href={`/essays/${next.slug}/`} class="np-link np-prev">
          &larr; {next.data.published.replace(/-/g, ".")} {next.data.title}
        </a>
      ) : <span></span>}
      {prev ? (
        <a href={`/essays/${prev.slug}/`} class="np-link np-next">
          {prev.data.published.replace(/-/g, ".")} {prev.data.title} &rarr;
        </a>
      ) : <span></span>}
    </nav>

    <span class="registration-mark" aria-hidden="true">&#9680;</span>
  </article>
</BaseLayout>
<style>
  .essay-deep-dive { position: relative; padding-bottom: 80px; }
  .head-band { max-width: 1120px; margin: 0 auto; padding: 60px 24px 0; }
  .dateline { font-family: var(--font-mono); font-size: 12px; font-weight: 500; letter-spacing: 1.6px; color: var(--ink-secondary); margin: 0 0 12px; display: flex; justify-content: space-between; }
  .dateline__city { color: var(--stamp-amber); }
  .reading-time { color: var(--ink-secondary); }
  .dateline-rule { border: none; border-top: 0.5px solid rgba(10, 62, 66, 0.25); margin: 0 0 24px; }
  .pills-row { display: flex; gap: 12px; margin: 0 0 16px; }
  .pill { font-family: var(--font-mono); font-size: 11px; font-weight: 500; letter-spacing: 1.8px; text-transform: uppercase; padding: 3px 8px; border: 1px solid currentColor; }
  .surface-pill { color: var(--ink); }
  .status-pill.status-published { color: var(--stamp-amber); }
  .status-pill.status-draft { color: var(--ink-secondary); }
  .page-title { font-family: var(--font-serif); font-size: clamp(40px, 5vw, 72px); font-weight: 400; letter-spacing: -0.4px; line-height: 1.05; color: var(--teal); margin: 0 0 12px; max-width: 880px; }
  .subtitle { font-family: var(--font-serif); font-size: clamp(20px, 2.2vw, 28px); font-weight: 300; font-style: italic; letter-spacing: -0.2px; color: var(--ink-secondary); margin: 0 0 16px; max-width: 720px; }
  .tags { font-family: var(--font-mono); font-size: 12px; font-weight: 500; letter-spacing: 1.6px; color: var(--ink-secondary); margin: 0 0 12px; }
  .tags .sep { color: var(--ink-secondary); }

  .essay-body { max-width: 680px; margin: 32px auto; padding: 0 24px; }
  .essay-body :global(article), .essay-body :global(p) {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 300;
    letter-spacing: -0.1px;
    line-height: 1.6;
    color: var(--ink);
  }
  .essay-body :global(h2) {
    font-family: var(--font-serif);
    font-size: clamp(28px, 3.2vw, 40px);
    font-weight: 500;
    letter-spacing: -0.4px;
    color: var(--teal);
    margin: 48px 0 16px;
  }
  .essay-body :global(p) { margin: 0 0 16px; }

  .inline-body-4q { max-width: 1120px; margin: 80px auto 0; padding: 0 24px; }
  .section-heading {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 2.4px;
    color: var(--teal);
    opacity: 0.8;
    text-transform: uppercase;
    margin: 0 0 24px;
  }
  .prose { max-width: 680px; }
  .prose :global(h2) {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 2.4px;
    color: var(--teal);
    text-transform: uppercase;
    margin: 48px 0 12px;
  }
  .prose :global(p) {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 300;
    line-height: 1.55;
    color: var(--ink);
    margin: 0 0 16px;
  }

  .next-prev { max-width: 1120px; margin: 64px auto 0; padding: 0 24px; display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .np-link { font-family: var(--font-mono); font-size: 13px; font-weight: 500; letter-spacing: 1.0px; color: var(--teal); text-decoration: none; border-bottom: 1px solid transparent; transition: border-color 160ms var(--ease-out); }
  .np-next { text-align: right; }
  .np-link:hover, .np-link:focus-visible { border-bottom-color: var(--teal); outline: none; }
  .registration-mark { position: absolute; right: 24px; bottom: 16px; font-size: 18px; color: var(--stamp-amber); opacity: 0.6; }

  @media (max-width: 767px) {
    .head-band { padding: 40px 16px 0; }
    .essay-body { padding: 0 16px; }
    .inline-body-4q { padding: 0 16px; }
    .next-prev { padding: 0 16px; grid-template-columns: 1fr; gap: 8px; }
    .np-next { text-align: left; }
    .registration-mark { right: 16px; }
  }
</style>
